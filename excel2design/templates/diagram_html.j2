<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ module.name }} — Block Diagram</title>
<style>
/* excel2design HTML block diagram v0.4 — light theme (SPEC §4.2) */
:root {
  --bg: #FFFFFF;
  --border: #888888;
  --light-border: #DDDDDD;
  --text: #333333;
  --muted: #888888;
  --wire-bg: #EEEEEE;
  --reg-bg: #DCE7F5;
  --logic-bg: #E8DDF2;
  --inout-bg: #F5F0DC;
  --clk-bg: #E0E0E0;
  --signed-bg: #FCE6CC;
  --heading-bg: #F7F7F7;
  --arrow-in: #2E86C1;
  --arrow-out: #E74C3C;
  --arrow-inout: #9B59B6;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  background: var(--bg);
  color: var(--text);
  font-family: "Menlo", "Consolas", "DejaVu Sans Mono", "Courier New", monospace;
  font-size: 13px;
  line-height: 1.5;
}
.block {
  min-width: 480px;
  max-width: 960px;
  margin: 20px auto;
  border: 2px solid var(--border);
  border-radius: 4px;
  background: var(--bg);
  overflow: hidden;
}
.block__title {
  text-align: center;
  font-weight: 700;
  font-size: 16px;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
  background: var(--heading-bg);
  letter-spacing: 0.5px;
}
.block__params {
  padding: 6px 16px;
  border-bottom: 1px solid var(--light-border);
  font-size: 12px;
  color: var(--muted);
  font-style: italic;
  background: var(--heading-bg);
}
.block__params span { font-style: normal; color: var(--text); }
.block__body {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  min-height: 60px;
}
.block__side {
  flex: 1 1 50%;
  padding: 10px 12px;
  min-width: 0;
}
.block__side--inputs { border-right: 2px solid var(--border); }
.block__side--outputs { }
.side__heading {
  font-weight: 700;
  text-transform: uppercase;
  font-size: 11px;
  letter-spacing: 1px;
  color: var(--muted);
  border-bottom: 1px solid var(--light-border);
  padding-bottom: 4px;
  margin-bottom: 8px;
}
.block__side--inputs .side__heading { text-align: left; }
.block__side--outputs .side__heading { text-align: right; }
.port {
  display: flex;
  flex-direction: column;
  margin: 6px 0;
  gap: 2px;
}
.block__side--outputs .port { align-items: flex-end; text-align: right; }
.block__side--inputs .port { align-items: flex-start; text-align: left; }
.port__name-row {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.port__arrow {
  font-size: 14px;
  line-height: 1;
}
.port__arrow--in {
  color: var(--arrow-in);
}
.port__arrow--out {
  color: var(--arrow-out);
}
.port__arrow--inout {
  color: var(--arrow-inout);
}
.port__name-text { font-weight: 600; font-size: 13px; color: var(--text); }
.badge {
  display: inline-block;
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  border: 1px solid var(--light-border);
  background: var(--wire-bg);
  color: var(--text);
}
.badge--width {
  font-family: inherit;
  font-weight: 500;
  letter-spacing: 0;
  text-transform: none;
}
.badge--wire { background: var(--wire-bg); }
.badge--reg  { background: var(--reg-bg); border-color: #B8CDE6; }
.badge--logic { background: var(--logic-bg); border-color: #D2BFE2; }
.badge--inout { background: var(--inout-bg); border-color: #D8C99B; }
.badge--clk  { background: var(--clk-bg); color: #555555; }
.badge--signed { background: var(--signed-bg); border-color: #E0B98A; }
.badge--default { background: #F2F2F2; color: #555555; }
.port__meta {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
  font-size: 11px;
  color: var(--muted);
}
.port__comment {
  font-style: italic;
  font-size: 11px;
  color: var(--muted);
  margin-top: 1px;
}
.block__inout-strip {
  border-top: 2px solid var(--border);
  padding: 10px 16px;
  background: var(--heading-bg);
}
.inout-strip__heading {
  font-weight: 700;
  text-transform: uppercase;
  font-size: 11px;
  letter-spacing: 1px;
  color: var(--muted);
  margin-bottom: 4px;
}
.inout-strip__row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16px;
  align-items: flex-start;
}
.inout-strip__row .port { margin: 0; }
.empty-msg {
  text-align: center;
  color: var(--muted);
  font-style: italic;
  padding: 18px 12px;
}
</style>
</head>
<body>
<div class="block">
  <div class="block__title">{{ module.name }}</div>
{%- if module.parameters %}
  <div class="block__params">
    parameters:
{%- for p in module.parameters %}
    <span>{{ p.name }}={{ p.value }}</span>{% if not loop.last %}, {% endif %}
{%- endfor %}
  </div>
{%- endif %}
{%- if inputs or outputs %}
  <div class="block__body">
    <div class="block__side block__side--inputs">
      <div class="side__heading">Inputs</div>
{%- if inputs %}
{%- for port in inputs %}
<div class="port">
  <div class="port__name-row">
    <span class="port__arrow port__arrow--in">&#8594;</span>
    <span class="port__name-text">{{ port.name }}</span>{% if port.width_str %}
    <span class="badge badge--width">{{ port.width_str }}</span>{% endif %}
    <span class="badge badge--{{ port.type_class }}">{{ port.type.value }}</span>{% if port.signed %}
    <span class="badge badge--signed">signed</span>{% endif %}
  </div>
{%- if port.default or port.clock %}
  <div class="port__meta">{% if port.default %}
    <span class="badge badge--default">{{ port.default }}</span>{% endif %}{% if port.clock and port.type.value in ("reg", "logic") %}
    <span class="badge badge--clk">clk: {{ port.clock }}</span>{% endif %}
  </div>
{%- endif %}
{%- if port.comment %}
  <div class="port__comment">{{ port.comment }}</div>
{%- endif %}
</div>
{%- endfor %}
{%- else %}
      <div class="empty-msg">—</div>
{%- endif %}
    </div>
    <div class="block__side block__side--outputs">
      <div class="side__heading">Outputs</div>
{%- if outputs %}
{%- for port in outputs %}
<div class="port">
  <div class="port__name-row">
    <span class="port__name-text">{{ port.name }}</span>{% if port.width_str %}
    <span class="badge badge--width">{{ port.width_str }}</span>{% endif %}
    <span class="badge badge--{{ port.type_class }}">{{ port.type.value }}</span>{% if port.signed %}
    <span class="badge badge--signed">signed</span>{% endif %}
    <span class="port__arrow port__arrow--out">&#8594;</span>
  </div>
{%- if port.default or port.clock %}
  <div class="port__meta">{% if port.default %}
    <span class="badge badge--default">{{ port.default }}</span>{% endif %}{% if port.clock and port.type.value in ("reg", "logic") %}
    <span class="badge badge--clk">clk: {{ port.clock }}</span>{% endif %}
  </div>
{%- endif %}
{%- if port.comment %}
  <div class="port__comment">{{ port.comment }}</div>
{%- endif %}
</div>
{%- endfor %}
{%- else %}
      <div class="empty-msg">—</div>
{%- endif %}
    </div>
  </div>
{%- endif %}
{%- if inouts %}
  <div class="block__inout-strip">
    <div class="inout-strip__heading">Inouts</div>
    <div class="inout-strip__row">
{%- for port in inouts %}
<div class="port">
  <div class="port__name-row">
    <span class="port__arrow port__arrow--inout">&#8596;</span>
    <span class="port__name-text">{{ port.name }}</span>{% if port.width_str %}
    <span class="badge badge--width">{{ port.width_str }}</span>{% endif %}
    <span class="badge badge--{{ port.type_class }}">{{ port.type.value }}</span>{% if port.signed %}
    <span class="badge badge--signed">signed</span>{% endif %}
    <span class="port__arrow port__arrow--inout">&#8596;</span>
  </div>
{%- if port.comment %}
  <div class="port__comment">{{ port.comment }}</div>
{%- endif %}
</div>
{%- endfor %}
    </div>
  </div>
{%- endif %}
{%- if not inputs and not outputs and not inouts %}
  <div class="empty-msg">module {{ module.name }} (no ports)</div>
{%- endif %}
</div>
</body>
</html>
