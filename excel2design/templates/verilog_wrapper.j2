{# Verilog wrapper template per SPEC §5.
   v0.4: column-aligned port/parameter declarations (pre-formatted in Python). #}
// =====================================================
// Module:    {{ module.name }}
// Source:    {{ source_file }}{{ " / sheet: " + source_sheet if source_sheet else "" }}
// =====================================================
// Company Confidential
// =====================================================
{%- if param_lines %}

module {{ module.name }} #(
{%- for line in param_lines %}
{{ line }}
{%- endfor %}
) (
{%- else %}

module {{ module.name }} (
{%- endif %}
    // ---------- INPUTS ----------
{%- for line in input_lines %}
{{ line }}
{%- endfor %}
{%- if output_lines %}
    // ---------- OUTPUTS ----------
{%- for line in output_lines %}
{{ line }}
{%- endfor %}
{%- endif %}
{%- if inout_lines %}
    // ---------- INOUTS ----------
{%- for line in inout_lines %}
{{ line }}
{%- endfor %}
{%- endif %}
);
{%- for port in internal_wires %}

    wire {{ port.width.to_verilog() }}{{ " " if port.width.to_verilog() else "" }}{{ port.name }};
{%- endfor %}
{%- if not internal_wires %}

    // (none — all wires are input ports)
{%- endif %}

    // ---------- INTERNAL REGS ----------
    // (output ports are already declared as regs in the port list)
{%- for port in internal_regs %}
    // {{ port.name }}: default = {{ port.default }} (declared in port list)
{%- endfor %}
{%- if regs_with_default %}

    // ---------- INITIAL ----------
    initial begin
{%- for port in regs_with_default %}
        {{ port.name }} = {{ port.default }};
{%- endfor %}
    end
{%- endif %}
{%- if always_groups %}
{%- for group in always_groups %}

    // ---------- {{ group.label }} ----------
    // Generated for: {{ group.regs | map(attribute='name') | join(', ') }}
    always @({% if group.is_async %}posedge {{ group.clock }} or negedge rst_n{% else %}posedge {{ group.clock }}{% endif %}) begin
        if (!rst_n) begin
{%- for reg in group.regs %}
            {{ reg.name }} <= {{ reg.default }};
{%- endfor %}
        end else begin
            // TODO: drive these regs
        end
    end
{%- endfor %}
{%- endif %}

    // =================================================
    // TODO: Implement {{ module.name }} logic
    //
    // Parameters: {{ param_names or '(none)' }}
    // Primary clock: {{ module.primary_clock() or '(none)' }}
    //
    // Reset signals per clock domain (wrapper uses `rst_n` in always blocks):
{{ reset_map }}
    //   → Replace `rst_n` with the actual reset port name for each domain.
    //
    // Registers and reset behavior:
{%- for port in module.regs() %}
    //   {{ port.name }} : {{ port.reset_type.value }} reset{% if port.default %} to {{ port.default }}{% endif %}{% if port.signed %}  (signed){% endif %}
{%- endfor %}
    // =================================================

endmodule
