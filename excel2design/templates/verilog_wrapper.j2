{# Verilog wrapper template per SPEC §5.
   v0.5: column-aligned ports/params, internal wires, submodule instances. #}
// =====================================================
// Module:    {{ module.name }}
// Source:    {{ source_file }}{{ " / sheet: " + source_sheet if source_sheet else "" }}
// =====================================================
// Company Confidential
// =====================================================
{%- if param_lines %}

module {{ module.name }} #(
{%- for line in param_lines %}
{{ line }}
{%- endfor %}
) (
{%- else %}

module {{ module.name }} (
{%- endif %}
    // ---------- INPUTS ----------
{%- for line in input_lines %}
{{ line }}
{%- endfor %}
{%- if output_lines %}
    // ---------- OUTPUTS ----------
{%- for line in output_lines %}
{{ line }}
{%- endfor %}
{%- endif %}
{%- if inout_lines %}
    // ---------- INOUTS ----------
{%- for line in inout_lines %}
{{ line }}
{%- endfor %}
{%- endif %}
);
{%- if wire_lines %}

    // ---------- INTERNAL WIRES ----------
{%- for line in wire_lines %}
{{ line }}
{%- endfor %}
{%- endif %}
{%- if regs_with_default %}

    // ---------- INITIAL ----------
    initial begin
{%- for reg in regs_with_default %}
        {{ reg.name }} = {{ reg.default }};
{%- endfor %}
    end
{%- endif %}
{%- if always_groups %}
{%- for group in always_groups %}

    // ---------- {{ group.label }} ----------
    always @({% if group.is_async %}posedge {{ group.clock }} or negedge rst_n{% else %}posedge {{ group.clock }}{% endif %}) begin
        if (!rst_n) begin
{%- for reg in group.regs %}
            {{ reg.name }} <= {{ reg.default }};
{%- endfor %}
        end else begin
            // TODO: drive these regs
        end
    end
{%- endfor %}
{%- endif %}
{%- if sub_instances %}

    // ---------- SUB-MODULES ----------
{%- for inst_str in sub_instances %}

{{ inst_str }}
{%- endfor %}
{%- endif %}

endmodule
